# Скопируй в .env и подставь реальные значения:  cp .env.example .env
# Файл .env в git не коммитится (см. .gitignore).

# Имя БД должно совпадать с productionDatabaseName из Sources/App/Consts/Database.swift
DATABASE_NAME=products
DATABASE_USERNAME=vapor
# Сгенерируй надёжный пароль, например:  openssl rand -base64 24
DATABASE_PASSWORD=change_me

# debug | info | notice | warning | error
LOG_LEVEL=info
